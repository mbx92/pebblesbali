// Landing Page CMS — Prisma Schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoomUnitStatus {
  active
  maintenance
  inactive
}

enum BookingStatus {
  pending
  confirmed
  checked_in
  checked_out
  cancelled
  no_show
}

enum BookingPaymentStatus {
  unpaid
  partially_paid
  paid
  refunded
  voided
}

enum LicenseOperationType {
  create
  update
  delete
  validate
  login
  logout
}

enum LicenseOperationTone {
  success
  warning
  error
  info
}

// ============ Models ============

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin") // "superadmin" | "admin" | "customer"
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("site_settings")
}

model Section {
  id        String      @id @default(cuid())
  businessType String
  templateKey String
  slug      String
  title     String
  subtitle  String?     @db.Text
  body      String?     @db.Text
  image     String?
  metadata  Json?
  sortOrder Int         @default(0)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([businessType, templateKey, slug])
  @@index([businessType, templateKey, sortOrder])
  @@map("sections")
}

model Collection {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  image       String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("collections")
}

model Product {
  id           String      @id @default(cuid())
  name         String
  slug         String      @unique
  description  String?     @db.Text
  price        Decimal     @db.Decimal(15, 2)
  image        String?
  gallery      String[]
  collectionId String
  collection   Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  isFeatured   Boolean     @default(false)
  isActive     Boolean     @default(true)
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("products")
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  content   String   @db.Text
  avatar    String?
  rating    Int      @default(5)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  alt       String?
  folder    String?
  createdAt DateTime @default(now())

  @@map("media")
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  // Shipping details (snapshot at order time)
  shipName    String
  shipEmail   String
  shipPhone   String
  shipAddress String      @db.Text
  shipCity    String
  shipProvince String
  shipPostal  String
  shipNotes   String?     @db.Text
  // Financials (in USD)
  subtotal       Decimal   @db.Decimal(15, 2)
  // Payment
  paymentStatus  String    @default("unpaid")  // unpaid | paid | failed | expired
  paymentMethod  String?
  paymentToken   String?
  paymentUrl     String?   @db.Text
  paidAt         DateTime?
  status         String    @default("pending") // pending | confirmed | processing | shipped | delivered | cancelled
  // Shipping (RajaOngkir)
  shippingCost    Decimal?  @db.Decimal(15, 2)  // IDR
  shippingCourier String?   // e.g. "jne", "jnt"
  shippingService String?   // e.g. "REG", "YES"
  items       OrderItem[]
  // OCS Workspace sync tracking
  ocsSyncedAt DateTime?
  ocsEntityId String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  productName String
  productImage String?
  price       Decimal @db.Decimal(15, 2)
  qty         Int

  @@map("order_items")
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?   @db.Text
  body        String?   @db.Text
  image       String?
  tags        String[]
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

model Property {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  description   String?        @db.Text
  timezone      String         @default("Asia/Makassar")
  currency      String         @default("IDR")
  checkInTime   String?
  checkOutTime  String?
  address       String?        @db.Text
  metadata      Json?
  isActive      Boolean        @default(true)
  roomTypes     RoomType[]
  roomUnits     RoomUnit[]
  bookings      Booking[]
  seasonalRates SeasonalRate[]
  blockedDates  BlockedDate[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("properties")
}

model RoomType {
  id              String         @id @default(cuid())
  propertyId      String
  property        Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name            String
  slug            String
  description     String?        @db.Text
  baseOccupancy   Int            @default(2)
  maxOccupancy    Int            @default(2)
  maxAdults       Int?
  maxChildren     Int?
  bedroomCount    Int?
  bathroomCount   Int?
  areaSqm         Int?
  bedConfiguration String?       @db.Text
  defaultNightlyRate Decimal     @db.Decimal(15, 2)
  extraAdultRate  Decimal?       @db.Decimal(15, 2)
  extraChildRate  Decimal?       @db.Decimal(15, 2)
  sortOrder       Int            @default(0)
  isActive        Boolean        @default(true)
  metadata        Json?
  roomUnits       RoomUnit[]
  seasonalRates   SeasonalRate[]
  bookingRooms    BookingRoom[]
  blockedDates    BlockedDate[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([propertyId, slug])
  @@index([propertyId, isActive, sortOrder])
  @@map("room_types")
}

model RoomUnit {
  id         String         @id @default(cuid())
  propertyId String
  property   Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomTypeId String
  roomType   RoomType       @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)
  code       String
  name       String?
  floor      String?
  status     RoomUnitStatus @default(active)
  isBookable Boolean        @default(true)
  metadata   Json?
  bookingRooms BookingRoom[]
  blockedDates BlockedDate[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([propertyId, code])
  @@index([roomTypeId, status, isBookable])
  @@map("room_units")
}

model Booking {
  id             String               @id @default(cuid())
  propertyId     String
  property       Property             @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  referenceCode  String               @unique
  source         String               @default("direct")
  status         BookingStatus        @default(pending)
  paymentStatus  BookingPaymentStatus @default(unpaid)
  guestFirstName String
  guestLastName  String?
  guestEmail     String
  guestPhone     String?
  guestCountry   String?
  notes          String?              @db.Text
  internalNotes  String?              @db.Text
  checkInDate    DateTime             @db.Date
  checkOutDate   DateTime             @db.Date
  adultCount     Int                  @default(1)
  childCount     Int                  @default(0)
  totalNights    Int
  subtotal       Decimal              @db.Decimal(15, 2)
  taxAmount      Decimal              @default(0) @db.Decimal(15, 2)
  feeAmount      Decimal              @default(0) @db.Decimal(15, 2)
  discountAmount Decimal              @default(0) @db.Decimal(15, 2)
  totalAmount    Decimal              @db.Decimal(15, 2)
  currency       String               @default("IDR")
  confirmedAt    DateTime?
  cancelledAt    DateTime?
  checkedInAt    DateTime?
  checkedOutAt   DateTime?
  bookingRooms   BookingRoom[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([propertyId, checkInDate, checkOutDate])
  @@index([status, paymentStatus])
  @@map("bookings")
}

model BookingRoom {
  id            String    @id @default(cuid())
  bookingId     String
  booking       Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  roomTypeId    String
  roomType      RoomType  @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)
  roomUnitId    String?
  roomUnit      RoomUnit? @relation(fields: [roomUnitId], references: [id], onDelete: SetNull)
  guestName     String?
  adults        Int       @default(1)
  children      Int       @default(0)
  nightlyRate   Decimal   @db.Decimal(15, 2)
  extraGuestFee Decimal   @default(0) @db.Decimal(15, 2)
  lineTotal     Decimal   @db.Decimal(15, 2)
  rateSnapshot  Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([bookingId])
  @@index([roomTypeId])
  @@index([roomUnitId])
  @@map("booking_rooms")
}

model SeasonalRate {
  id                String    @id @default(cuid())
  propertyId        String
  property          Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomTypeId        String?
  roomType          RoomType? @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)
  name              String
  startDate         DateTime  @db.Date
  endDate           DateTime  @db.Date
  nightlyRate       Decimal   @db.Decimal(15, 2)
  minStay           Int       @default(1)
  closedToArrival   Boolean   @default(false)
  closedToDeparture Boolean   @default(false)
  priority          Int       @default(0)
  isActive          Boolean   @default(true)
  metadata          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([propertyId, startDate, endDate, isActive])
  @@index([roomTypeId, startDate, endDate])
  @@map("seasonal_rates")
}

model BlockedDate {
  id         String    @id @default(cuid())
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomTypeId String?
  roomType   RoomType? @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)
  roomUnitId String?
  roomUnit   RoomUnit? @relation(fields: [roomUnitId], references: [id], onDelete: SetNull)
  startDate  DateTime  @db.Date
  endDate    DateTime  @db.Date
  reason     String?
  notes      String?   @db.Text
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([propertyId, startDate, endDate, isActive])
  @@index([roomTypeId, startDate, endDate])
  @@index([roomUnitId, startDate, endDate])
  @@map("blocked_dates")
}

model LicensePlan {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  features    String[]
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  licenses    License[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([sortOrder])
  @@map("license_plans")
}

model License {
  id          String      @id @default(cuid())
  licenseKey  String      @unique
  clientName  String
  clientEmail String?
  domain      String      @unique
  planId      String
  plan        LicensePlan @relation(fields: [planId], references: [id])
  features    String[]
  isActive    Boolean     @default(true)
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([planId])
  @@map("licenses")
}

model LicenseOperation {
  id        String               @id @default(cuid())
  type      LicenseOperationType
  title     String
  subject   String
  actor     String
  detail    String
  tone      LicenseOperationTone
  createdAt DateTime             @default(now())

  @@index([createdAt])
  @@map("license_operations")
}

model LicenseSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  email     String
  name      String
  role      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("license_sessions")
}
